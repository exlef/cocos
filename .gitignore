# =======================================================
# Cocos Creator 3.x .gitignore
# =======================================================

# 1. Engine Generated Directories (DO NOT COMMIT)
# -------------------------------------------------------
/library/
/local/
/temp/
/build/
/profiles/
/.creator/

# 2. OS Generated Files
# -------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 3. Log Files
# -------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 4. Node.js / Package Manager
# -------------------------------------------------------
# Ignore node_modules if you use custom npm packages. 
# Keep package.json and package-lock.json committed!
node_modules/

# 5. IDE / Editor Specific Files
# -------------------------------------------------------
/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VS Code - Ignore workspace local settings but keep project-wide configs
/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json